{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@app/*": ["../app/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../app/components/docs/**/*.ts",
    "../app/components/docs/**/*.tsx",
    "../app/lib/**/*.ts"
  ]
}
