{
  "name": "compendus",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "pnpm run build && node --import tsx server.ts",
    "dev": "vite",
    "build": "tsx scripts/build-worker.ts && react-flight-router build && tsx scripts/copy-migrations.ts",
    "build:worker": "tsx scripts/build-worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "oxfmt --check && oxlint",
    "lint:fix": "oxfmt --write && oxlint",
    "make-admin": "tsx scripts/make-admin.ts",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@hono/node-server": "^1.19.11",
    "@tanstack/react-virtual": "^3.13.23",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.8.0",
    "busboy": "^1.6.0",
    "canvas": "^3.2.1",
    "codemirror": "^6.0.2",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "jszip": "^3.10.1",
    "mime-types": "^3.0.2",
    "music-metadata": "^11.12.3",
    "node-id3": "^0.2.9",
    "node-unrar-js": "^2.0.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdf2pic": "^3.2.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-flight-router": "^0.4.0",
    "react-server-dom-webpack": "^19.2.4",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/busboy": "^1.5.4",
    "@types/mime-types": "^3.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260319.1",
    "@vitejs/plugin-react": "6.0.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "8.0.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.75.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxfmt --write",
      "oxlint"
    ],
    "*.{json,css,md}": [
      "oxfmt --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "canvas",
      "core-js",
      "es5-ext",
      "esbuild",
      "puppeteer"
    ],
    "overrides": {
      "pdfjs-dist": "^5.4.530"
    }
  }
}
